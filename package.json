{
  "name": "obsidian-dynamic-wallpapers-plugin",
  "private": true,
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "svelte-check --tsconfig ./tsconfig.json && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "esbuild": "^0.25.0",
    "esbuild-svelte": "^0.9.3",
    "obsidian": "^1.8.7",
    "svelte": "^5.43.12",
    "svelte-check": "^4.6.0",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.0"
  }
}
